# LLM
# The verified scaffold stays on ai@5. Plain provider/model strings route through Vercel AI Gateway.
AI_GATEWAY_API_KEY=

# Supabase, optional for this scaffold surface
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Build-week integrations, all mocked/bundled when empty
# MiroShark swarm-sim (simulate_reception). Only the URL is required to switch off the mock.
MIROSHARK_URL=
MIROSHARK_API_KEY=          # optional bearer token
MIROSHARK_ADMIN_TOKEN=      # optional, required to publish + read signal.json verdicts
MIROSHARK_TIMEOUT_MS=       # optional, per-request timeout, defaults to 30000

# Scraped web context for simulate_reception (see lib/scrape-context.ts). Opt-in — off by
# default even if TINYFISH_API_KEY is set, so it never adds cost/latency silently.
MIROSHARK_SCRAPE_ENABLED=   # set to "true" to enable
TINYFISH_API_KEY=           # optional. Search+Fetch are free (docs.tinyfish.ai). Without
                             # it, fetching falls back to MiroShark's own /api/graph/fetch-url
                             # and source discovery (search) is skipped entirely.

# Nano Banana (gen_skins concept art). Bundled SVGs used when empty.
NANO_BANANA_KEY=
NANO_BANANA_MODEL=        # optional, defaults to gemini-2.5-flash-image

# Meshy (to_3d image-to-3D). Bundled GLB used when empty.
MESHY_KEY=

# Only needed when running MiroShark yourself
NEO4J_URI=
OPENROUTER_API_KEY_MIROSHARK=
