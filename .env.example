# ─── LLM ─────────────────────────────────────────────────────────────────────
# The agent uses AI SDK v5 with a plain "provider/model" string routed through the
# Vercel AI Gateway. Set ONE of these:
AI_GATEWAY_API_KEY=          # preferred on Vercel (or use Vercel OIDC automatically)
# ANTHROPIC_API_KEY=         # fallback: swap lib/ai.ts to @ai-sdk/anthropic
# OPENROUTER_API_KEY=        # fallback: swap lib/ai.ts to @ai-sdk/openrouter

# ─── MiroShark (demo-data generator, optional) ───────────────────────────────
# Leave EMPTY to use the built-in MockSimClient so the app deploys green.
# Set to your running MiroShark HTTP endpoint during build week (Day-1 spike).
# MiroShark HTTP endpoint; leave empty to use the built-in mock client.
MIROSHARK_URL=
# Bearer token for MiroShark's admin-gated publish step.
MIROSHARK_ADMIN_TOKEN=
# Enable optional scrape-context enrichment before MiroShark ingestion.
MIROSHARK_SCRAPE_ENABLED=false
# TinyFish Search/Fetch API key for optional scrape-context discovery.
TINYFISH_API_KEY=
# Optional Nano Banana key for live creative image generation.
NANO_BANANA_KEY=
NEO4J_URI=                   # only if you run MiroShark yourself
OPENROUTER_API_KEY_MIROSHARK=

# NOTE: All statistics live in lib/stats.ts (deterministic TypeScript, the single source of
# truth, validated against scipy/statsmodels in `npm run eval`). There is no external stats
# service — the LLM never computes statistics.
