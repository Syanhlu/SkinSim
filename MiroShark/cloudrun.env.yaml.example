# Cloud Run environment variables template (consumed by scripts/deploy_cloudrun.sh
# via `gcloud run deploy --env-vars-file=cloudrun.env.yaml`).
#
# Usage:
#   cp cloudrun.env.yaml.example cloudrun.env.yaml   # then fill in real values
#   ./scripts/deploy_cloudrun.sh
#
# cloudrun.env.yaml is gitignored — DO NOT commit real secrets.
# Format: a flat YAML mapping of ENV_NAME: "value" (values must be strings).
# NOTE: do NOT set PORT here — Cloud Run injects it and rejects it in this file.

# === Application Mode ===
# Must be "false" on Cloud Run (see railway.env.example for why).
FLASK_DEBUG: "false"

# === Internal API Authentication ===
# Required: protects /api/* routes. Generate with: openssl rand -hex 32
MIROSHARK_INTERNAL_KEY: "your-secret-key-here"

# === Flask Configuration ===
SECRET_KEY: "your-flask-secret-key-here"

# === LLM Configuration ===
LLM_PROVIDER: "openai"
LLM_API_KEY: "your-llm-api-key-here"
LLM_BASE_URL: "https://api.openai.com/v1"
LLM_MODEL_NAME: "xiaomi/mimo-v2.5"

# === Neo4j Configuration ===
NEO4J_URI: "bolt://your-neo4j-host:7687"
NEO4J_USER: "neo4j"
NEO4J_PASSWORD: "your-neo4j-password-here"

# === Embedding Configuration ===
EMBEDDING_PROVIDER: "ollama"
EMBEDDING_MODEL: "nomic-embed-text"
EMBEDDING_BASE_URL: "http://your-ollama-host:11434"
EMBEDDING_DIMENSIONS: "768"

# === Observability ===
MIROSHARK_LOG_LEVEL: "info"
