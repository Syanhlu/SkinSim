# Railway Environment Variables Template
# Copy this to Railway environment variables when deploying
# DO NOT commit actual values to the repository

# === Railway Runtime ===
# Railway injects PORT automatically and run.py/gunicorn read it — do NOT set
# it manually here (a hardcoded value would override Railway's binding).
# FLASK_PORT is only used as a fallback when PORT is absent (local runs).
# PORT=8080

# === Application Mode ===
# MUST be false on any deployed environment. FLASK_DEBUG defaults to "true",
# and if it is left true the internal-key guard fails OPEN when no key is set.
# (On Railway/Cloud Run the guard also fails closed via platform detection,
# but setting this is the primary, explicit safeguard.)
FLASK_DEBUG=false

# === Internal API Authentication ===
# Required: Secret key for internal API authentication
# Protects /api/* routes (except /health and /api/docs)
# Must be set in Railway environment variables
# Generate with: openssl rand -hex 32
MIROSHARK_INTERNAL_KEY=your-secret-key-here

# === Flask Configuration ===
# Secret key for Flask session management
SECRET_KEY=your-flask-secret-key-here

# === LLM Configuration ===
# LLM provider: "openai" (default) or "claude-code" (local CLI)
LLM_PROVIDER=openai
# OpenAI-compatible API key
LLM_API_KEY=your-llm-api-key-here
# Base URL for LLM API (default: https://api.openai.com/v1)
LLM_BASE_URL=https://api.openai.com/v1
# Model name for default LLM operations
LLM_MODEL_NAME=xiaomi/mimo-v2.5

# === Smart Model Configuration ===
# Stronger model for intelligence-sensitive workflows
# When empty, uses default LLM config above
SMART_PROVIDER=
SMART_API_KEY=
SMART_BASE_URL=
SMART_MODEL_NAME=

# === Neo4j Configuration ===
# Neo4j connection URI
NEO4J_URI=bolt://localhost:7687
# Neo4j username
NEO4J_USER=neo4j
# Neo4j password
NEO4J_PASSWORD=your-neo4j-password-here

# === Embedding Configuration ===
# Embedding provider: "ollama" (default) or "openai"
EMBEDDING_PROVIDER=ollama
# Embedding model name
EMBEDDING_MODEL=nomic-embed-text
# Base URL for embedding API
EMBEDDING_BASE_URL=http://localhost:11434
# API key for embedding API (if required)
EMBEDDING_API_KEY=
# Embedding dimensions
EMBEDDING_DIMENSIONS=768
# Embedding batch size
EMBEDDING_BATCH_SIZE=128

# === Reranker Configuration ===
# Enable/disable reranking
RERANKER_ENABLED=true
# Reranker model name
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Number of candidates before reranking
RERANKER_CANDIDATES=30

# === Graph Search Configuration ===
# Enable/disable graph search
GRAPH_SEARCH_ENABLED=true
# Number of hops for graph search
GRAPH_SEARCH_HOPS=1
# Number of seed entities per query
GRAPH_SEARCH_SEEDS=5

# === Entity Resolution Configuration ===
# Enable/disable entity resolution
ENTITY_RESOLUTION_ENABLED=true
# Use LLM for ambiguous matches
ENTITY_RESOLUTION_USE_LLM=true

# === Contradiction Detection Configuration ===
# Enable/disable contradiction detection
CONTRADICTION_DETECTION_ENABLED=true

# === Community Configuration ===
# Minimum community size
COMMUNITY_MIN_SIZE=3
# Maximum community count
COMMUNITY_MAX_COUNT=30

# === Reasoning Trace Configuration ===
# Enable/disable reasoning trace persistence
REASONING_TRACE_ENABLED=true

# === Wonderwall Configuration ===
# Default max rounds for simulation
WONDERWALL_DEFAULT_MAX_ROUNDS=10

# === Web Enrichment Configuration ===
# Enable/disable web enrichment
WEB_ENRICHMENT_ENABLED=true
# Optional dedicated model for web research
WEB_SEARCH_MODEL=
# Optional SearXNG instance for real web search with any model (precedence
# over WEB_SEARCH_MODEL; falls back to it on failure)
MIROSHARK_SEARXNG_BASE_URL=
# Optional Firecrawl-for-agents instance for URL document ingestion
MIROSHARK_FIRECRAWL_BASE_URL=
MIROSHARK_FIRECRAWL_API_KEY=

# === Wonderwall Model Configuration ===
# Optional dedicated model for Wonderwall simulation
WONDERWALL_MODEL_NAME=
# Optional per-slot endpoint override for Wonderwall
WONDERWALL_API_KEY=
WONDERWALL_BASE_URL=

# === NER Model Configuration ===
# Optional dedicated model for entity extraction
NER_MODEL_NAME=
NER_BASE_URL=
NER_API_KEY=

# === Observability Configuration ===
# Enable/disable prompt logging
MIROSHARK_LOG_PROMPTS=false
# Log level: debug|info|warn
MIROSHARK_LOG_LEVEL=info

# === Anthropic Prompt Caching ===
# Enable/disable prompt caching for Claude models
LLM_PROMPT_CACHING_ENABLED=true

# === LLM Reasoning Configuration ===
# Disable chain-of-thought on reasoning-capable models
LLM_DISABLE_REASONING=true

# === Report Agent Configuration ===
# Max tool calls for report agent
REPORT_AGENT_MAX_TOOL_CALLS=5
# Max reflection rounds for report agent
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# Temperature for report agent
REPORT_AGENT_TEMPERATURE=0.5

# === Webhook Configuration ===
# Outbound webhook URL for simulation completion events
WEBHOOK_URL=

# === Public Base URL ===
# Public base URL of this deployment (e.g., https://miroshark.app)
PUBLIC_BASE_URL=

# === OriginTrail DKG Configuration ===
# DKG API URL
DKG_API_URL=
# DKG auth token
DKG_AUTH_TOKEN=
# DKG context graph ID
DKG_CONTEXT_GRAPH_ID=
# DKG network (testnet or mainnet)
DKG_NETWORK=testnet

# === WaybackClaw Configuration ===
# WaybackClaw API URL
WAYBACKCLAW_API_URL=
# WaybackClaw agent token
WAYBACKCLAW_AGENT_TOKEN=
# WaybackClaw agent category
WAYBACKCLAW_AGENT_CATEGORY=

# === Demographics Configuration ===
# Country code for demographic grounding
DEMOGRAPHICS_COUNTRY=

# === Sitemap Configuration ===
# Enable/disable sitemap
ENABLE_SITEMAP=true
