      "Novena", "Orchard", "Outram", "Pasir Ris", "Paya Lebar",
      "Punggol", "Queenstown", "River Valley", "Rochor", "Sembawang",
      "Sengkang", "Serangoon", "Singapore River", "Tampines", "Tanglin",
      "Tengah", "Toa Payoh", "Woodlands", "Yishun"
